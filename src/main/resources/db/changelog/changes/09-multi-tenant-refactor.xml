<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">

    <changeSet id="09-multi-tenant-refactor" author="rafael">
        <createTable tableName="workspace_memberships">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="workspace_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="role" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="work_policy_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="manager_id" type="UUID"/>
        </createTable>

        <addForeignKeyConstraint baseTableName="workspace_memberships" baseColumnNames="user_id" constraintName="fk_wm_user" referencedTableName="users" referencedColumnNames="id"/>
        <addForeignKeyConstraint baseTableName="workspace_memberships" baseColumnNames="workspace_id" constraintName="fk_wm_workspace" referencedTableName="workspaces" referencedColumnNames="id"/>
        <addForeignKeyConstraint baseTableName="workspace_memberships" baseColumnNames="work_policy_id" constraintName="fk_wm_policy" referencedTableName="work_policies" referencedColumnNames="id"/>
        <addForeignKeyConstraint baseTableName="workspace_memberships" baseColumnNames="manager_id" constraintName="fk_wm_manager" referencedTableName="users" referencedColumnNames="id"/>

        <dropForeignKeyConstraint baseTableName="users" constraintName="fk_users_work_policy"/>
        <dropForeignKeyConstraint baseTableName="users" constraintName="fk_users_manager"/>
        <dropColumn tableName="users" columnName="role"/>
        <dropColumn tableName="users" columnName="work_policy_id"/>
        <dropColumn tableName="users" columnName="manager_id"/>
    </changeSet>

</databaseChangeLog>